# 环境变量示例（复制为 .env 后填写；.env 不入库）
# 仅承载「环境相关 / 敏感」覆盖项；其余配置留在 settings.yaml。
# 本地开发：set -a; source config/.env; set +a
# 生产部署：由 systemd 的 EnvironmentFile= 指向此文件（去掉 .example）。

# 运行环境：dev / prod
ETF_ENV=dev

# 是否打印调试信息
ETF_DEBUG=false

# API 监听地址（生产必须 127.0.0.1，由 Nginx 反代）
ETF_API_HOST=127.0.0.1
ETF_API_PORT=8000

# 数据目录（相对 config 或绝对路径均可）
ETF_DATA_DIR=../data
ETF_LOG_DIR=../data/logs
ETF_SQLITE_FILE=etf_monitor.db

# 日志级别：DEBUG / INFO / WARNING / ERROR
ETF_LOG_LEVEL=INFO

# 数据源模式：real / mock（mock 仅 dev/test，禁止生产）
ETF_DATA_SOURCE_MODE=real
ETF_DATA_SOURCE_PREFERRED=em

# 调度时区与开关
ETF_SCHEDULER_TZ=Asia/Shanghai
ETF_SCHEDULER_ENABLED=true
